<?xml version="1.0"?>
<!--
  Wave Rover (Waveshare) 194 x 168 x 100 mm.
  Medidas marcadas [calibrar] son aproximadas: ajustar con regla sobre el robot.
  Convencion REP-103: x adelante, y izquierda, z arriba.
-->
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="waver">

  <!-- Chasis -->
  <xacro:property name="body_length" value="0.194"/>
  <xacro:property name="body_width"  value="0.110"/>   <!-- sin ruedas [calibrar] -->
  <xacro:property name="body_height" value="0.055"/>   <!-- [calibrar] -->
  <xacro:property name="ground_clearance" value="0.020"/> <!-- [calibrar] -->

  <!-- Ruedas -->
  <xacro:property name="wheel_radius" value="0.030"/>  <!-- [calibrar] -->
  <xacro:property name="wheel_width"  value="0.026"/>  <!-- [calibrar] -->
  <xacro:property name="wheel_separation" value="0.125"/> <!-- entre centros [calibrar] -->
  <xacro:property name="wheel_base" value="0.110"/>    <!-- entre ejes [calibrar] -->

  <!-- Sensores (alturas sobre base_link) [calibrar todos] -->
  <xacro:property name="lidar_x" value="0.0"/>
  <xacro:property name="lidar_z" value="0.085"/>
  <xacro:property name="oak_x" value="0.085"/>
  <xacro:property name="oak_z" value="0.060"/>

  <material name="black"><color rgba="0.15 0.15 0.15 1"/></material>
  <material name="grey"><color rgba="0.5 0.5 0.5 1"/></material>
  <material name="blue"><color rgba="0.2 0.4 0.8 1"/></material>

  <!-- base_footprint en el suelo, base_link en el centro del chasis -->
  <link name="base_footprint"/>

  <link name="base_link">
    <visual>
      <geometry><box size="${body_length} ${body_width} ${body_height}"/></geometry>
      <material name="grey"/>
    </visual>
    <collision>
      <geometry><box size="${body_length} ${body_width} ${body_height}"/></geometry>
    </collision>
    <inertial>
      <mass value="1.2"/>
      <inertia ixx="0.002" ixy="0" ixz="0" iyy="0.004" iyz="0" izz="0.005"/>
    </inertial>
  </link>

  <joint name="base_footprint_joint" type="fixed">
    <parent link="base_footprint"/>
    <child link="base_link"/>
    <origin xyz="0 0 ${ground_clearance + body_height/2}" rpy="0 0 0"/>
  </joint>

  <!-- Ruedas (fijas: sin encoders, no publicamos su giro) -->
  <xacro:macro name="wheel" params="name x y">
    <link name="${name}_wheel">
      <visual>
        <geometry><cylinder radius="${wheel_radius}" length="${wheel_width}"/></geometry>
        <origin rpy="${pi/2} 0 0"/>
        <material name="black"/>
      </visual>
      <collision>
        <geometry><cylinder radius="${wheel_radius}" length="${wheel_width}"/></geometry>
        <origin rpy="${pi/2} 0 0"/>
      </collision>
      <inertial>
        <mass value="0.05"/>
        <inertia ixx="0.00002" ixy="0" ixz="0" iyy="0.00002" iyz="0" izz="0.00002"/>
      </inertial>
    </link>
    <joint name="${name}_wheel_joint" type="fixed">
      <parent link="base_link"/>
      <child link="${name}_wheel"/>
      <origin xyz="${x} ${y} ${-body_height/2 - ground_clearance + wheel_radius}" rpy="0 0 0"/>
    </joint>
  </xacro:macro>

  <xacro:wheel name="front_left"  x="${wheel_base/2}"  y="${(wheel_separation + wheel_width)/2}"/>
  <xacro:wheel name="front_right" x="${wheel_base/2}"  y="${-(wheel_separation + wheel_width)/2}"/>
  <xacro:wheel name="rear_left"   x="${-wheel_base/2}" y="${(wheel_separation + wheel_width)/2}"/>
  <xacro:wheel name="rear_right"  x="${-wheel_base/2}" y="${-(wheel_separation + wheel_width)/2}"/>

  <!-- IMU (en la placa driver, centro del chasis) -->
  <link name="imu_link"/>
  <joint name="imu_joint" type="fixed">
    <parent link="base_link"/>
    <child link="imu_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <!-- Lidar STL-06 (montado arriba, centro) -->
  <link name="laser_frame">
    <visual>
      <geometry><cylinder radius="0.019" length="0.025"/></geometry>
      <material name="black"/>
    </visual>
  </link>
  <joint name="laser_joint" type="fixed">
    <parent link="base_link"/>
    <child link="laser_frame"/>
    <origin xyz="${lidar_x} 0 ${lidar_z}" rpy="0 0 0"/>
  </joint>

  <!-- OAK-D Lite (frontal). oak_link es el cuerpo; los frames opticos los
       publica depthai_ros_driver como hijos (oak_rgb_camera_optical_frame...) -->
  <link name="oak_link">
    <visual>
      <geometry><box size="0.017 0.091 0.028"/></geometry>
      <material name="blue"/>
    </visual>
  </link>
  <joint name="oak_joint" type="fixed">
    <parent link="base_link"/>
    <child link="oak_link"/>
    <origin xyz="${oak_x} 0 ${oak_z}" rpy="0 0 0"/>
  </joint>

</robot>
