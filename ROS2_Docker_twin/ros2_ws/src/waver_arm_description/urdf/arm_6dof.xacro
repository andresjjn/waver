<?xml version="1.0"?>
<!--
  Brazo 6DOF de aluminio (kit "Red Sun Global" / ThanksBuyer, manual 30 pág.)
  Cadena real confirmada en el manual (pág. 28):
    A = yaw de base (sobre rodamiento grande)   -> ${prefix}yaw_joint        (eje Z)
    B = hombro (pitch)                           -> ${prefix}shoulder_joint   (eje Y)
    C = codo (pitch, bloque doble servo)         -> ${prefix}elbow_joint      (eje Y)
    D = muñeca pitch                             -> ${prefix}wrist_pitch_joint(eje Y)
    E = muñeca roll                              -> ${prefix}wrist_roll_joint (eje Z local)
    F = garra de engranajes (2 dedos espejados)  -> ${prefix}finger_l_joint + mimic

  Servos: formato 40x20 spline 25T (kit=25kg 180° PWM 0.5-2.5ms; nosotros MG996R).
  TODAS las longitudes son [calibrar]: estimadas de las fotos del manual y del
  estándar de la familia; se miden con calibrador al llegar el kit y se corrigen
  aquí UNA sola vez (el resto del modelo se actualiza solo).

  Modelado en pose "vela" (brazo apuntando +Z, cero de todos los joints).
  Convención REP-103. Masas aproximadas: ~0.9 kg/brazo con 6 servos.
-->
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

  <!-- ==================== dimensiones [calibrar] ==================== -->
  <xacro:property name="base_lx"        value="0.095"/>  <!-- caja base (aloja servo A) -->
  <xacro:property name="base_ly"        value="0.095"/>
  <xacro:property name="base_lz"        value="0.062"/>
  <xacro:property name="turntable_r"    value="0.042"/>  <!-- disco sobre rodamiento -->
  <xacro:property name="turntable_h"    value="0.012"/>
  <xacro:property name="shoulder_off_z" value="0.045"/>  <!-- disco -> eje hombro -->
  <xacro:property name="upper_len"      value="0.120"/>  <!-- hombro -> codo -->
  <xacro:property name="fore_len"       value="0.090"/>  <!-- codo -> muñeca pitch -->
  <xacro:property name="wrist_len"      value="0.055"/>  <!-- muñeca pitch -> brida roll -->
  <xacro:property name="gripper_base_h" value="0.045"/>  <!-- brida roll -> eje dedos -->
  <xacro:property name="finger_len"     value="0.075"/>  <!-- dedo dentado -->
  <xacro:property name="finger_sep"     value="0.024"/>  <!-- separación ejes engranaje -->
  <xacro:property name="plate_w"        value="0.030"/>  <!-- ancho placas eslabón -->
  <xacro:property name="plate_t"        value="0.060"/>  <!-- fondo par de placas -->

  <!-- servo 40x20 clase MG996R -->
  <xacro:property name="servo_lx" value="0.041"/>
  <xacro:property name="servo_ly" value="0.020"/>
  <xacro:property name="servo_lz" value="0.038"/>

  <!-- limites: servos de 180 grados -> +/- 90 desde el centro -->
  <xacro:property name="lim"        value="${pi/2}"/>
  <xacro:property name="effort_nm"  value="1.0"/>   <!-- MG996R ~10 kg.cm = 0.98 N.m -->
  <xacro:property name="vel_rads"   value="3.0"/>   <!-- ~0.17s/60deg con margen -->

  <!-- ==================== macros de inercia ==================== -->
  <xacro:macro name="inercia_caja" params="m x y z">
    <inertial>
      <mass value="${m}"/>
      <inertia ixx="${m*(y*y+z*z)/12.0}" iyy="${m*(x*x+z*z)/12.0}"
               izz="${m*(x*x+y*y)/12.0}" ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </xacro:macro>
  <xacro:macro name="inercia_cilindro" params="m r h">
    <inertial>
      <mass value="${m}"/>
      <inertia ixx="${m*(3*r*r+h*h)/12.0}" iyy="${m*(3*r*r+h*h)/12.0}"
               izz="${m*r*r/2.0}" ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </xacro:macro>

  <!-- visual de un servo 40x20 (caja roja) -->
  <xacro:macro name="servo_visual" params="xyz rpy:='0 0 0'">
    <visual>
      <origin xyz="${xyz}" rpy="${rpy}"/>
      <geometry><box size="${servo_lx} ${servo_ly} ${servo_lz}"/></geometry>
      <material name="servo_rojo"/>
    </visual>
  </xacro:macro>

  <!-- ==================== la macro del brazo ==================== -->
  <xacro:macro name="waver_arm" params="prefix parent *origin">

    <!-- anclaje al padre (placa-torso) -->
    <joint name="${prefix}mount_joint" type="fixed">
      <parent link="${parent}"/>
      <child link="${prefix}base_link"/>
      <xacro:insert_block name="origin"/>
    </joint>

    <!-- base: caja metalica con servo A y electronica -->
    <link name="${prefix}base_link">
      <visual>
        <origin xyz="0 0 ${base_lz/2}"/>
        <geometry><box size="${base_lx} ${base_ly} ${base_lz}"/></geometry>
        <material name="aluminio"/>
      </visual>
      <collision>
        <origin xyz="0 0 ${base_lz/2}"/>
        <geometry><box size="${base_lx} ${base_ly} ${base_lz}"/></geometry>
      </collision>
      <xacro:inercia_caja m="0.25" x="${base_lx}" y="${base_ly}" z="${base_lz}"/>
    </link>

    <!-- A: yaw de base sobre rodamiento -->
    <joint name="${prefix}yaw_joint" type="revolute">
      <parent link="${prefix}base_link"/>
      <child link="${prefix}turntable_link"/>
      <origin xyz="0 0 ${base_lz}"/>
      <axis xyz="0 0 1"/>
      <limit lower="${-lim}" upper="${lim}" effort="${effort_nm}" velocity="${vel_rads}"/>
    </joint>

    <link name="${prefix}turntable_link">
      <visual>
        <origin xyz="0 0 ${turntable_h/2}"/>
        <geometry><cylinder radius="${turntable_r}" length="${turntable_h}"/></geometry>
        <material name="gris_oscuro"/>
      </visual>
      <!-- horquilla del hombro -->
      <visual>
        <origin xyz="0 0 ${turntable_h + shoulder_off_z/2}"/>
        <geometry><box size="0.050 0.070 ${shoulder_off_z}"/></geometry>
        <material name="aluminio"/>
      </visual>
      <collision>
        <origin xyz="0 0 ${(turntable_h + shoulder_off_z)/2}"/>
        <geometry><box size="0.070 0.080 ${turntable_h + shoulder_off_z}"/></geometry>
      </collision>
      <xacro:inercia_caja m="0.12" x="0.07" y="0.08" z="${turntable_h + shoulder_off_z}"/>
    </link>

    <!-- B: hombro -->
    <joint name="${prefix}shoulder_joint" type="revolute">
      <parent link="${prefix}turntable_link"/>
      <child link="${prefix}upper_arm_link"/>
      <origin xyz="0 0 ${turntable_h + shoulder_off_z}"/>
      <axis xyz="0 1 0"/>
      <limit lower="${-lim}" upper="${lim}" effort="${effort_nm}" velocity="${vel_rads}"/>
    </joint>

    <link name="${prefix}upper_arm_link">
      <visual>
        <origin xyz="0 0 ${upper_len/2}"/>
        <geometry><box size="${plate_w} ${plate_t} ${upper_len}"/></geometry>
        <material name="aluminio"/>
      </visual>
      <xacro:servo_visual xyz="0 ${plate_t/2 + servo_ly/2} 0"/>
      <collision>
        <origin xyz="0 0 ${upper_len/2}"/>
        <geometry><box size="${plate_w} ${plate_t + 2*servo_ly} ${upper_len}"/></geometry>
      </collision>
      <xacro:inercia_caja m="0.18" x="${plate_w}" y="${plate_t}" z="${upper_len}"/>
    </link>

    <!-- C: codo (bloque doble servo del manual, pag. 15) -->
    <joint name="${prefix}elbow_joint" type="revolute">
      <parent link="${prefix}upper_arm_link"/>
      <child link="${prefix}forearm_link"/>
      <origin xyz="0 0 ${upper_len}"/>
      <axis xyz="0 1 0"/>
      <limit lower="${-lim}" upper="${lim}" effort="${effort_nm}" velocity="${vel_rads}"/>
    </joint>

    <link name="${prefix}forearm_link">
      <visual>
        <origin xyz="0 0 ${fore_len/2}"/>
        <geometry><box size="${plate_w} ${plate_t} ${fore_len}"/></geometry>
        <material name="aluminio"/>
      </visual>
      <xacro:servo_visual xyz="0 ${-(plate_t/2 + servo_ly/2)} 0"/>
      <collision>
        <origin xyz="0 0 ${fore_len/2}"/>
        <geometry><box size="${plate_w} ${plate_t + 2*servo_ly} ${fore_len}"/></geometry>
      </collision>
      <xacro:inercia_caja m="0.16" x="${plate_w}" y="${plate_t}" z="${fore_len}"/>
    </link>

    <!-- D: muñeca pitch -->
    <joint name="${prefix}wrist_pitch_joint" type="revolute">
      <parent link="${prefix}forearm_link"/>
      <child link="${prefix}wrist_link"/>
      <origin xyz="0 0 ${fore_len}"/>
      <axis xyz="0 1 0"/>
      <limit lower="${-lim}" upper="${lim}" effort="${effort_nm}" velocity="${vel_rads}"/>
    </joint>

    <link name="${prefix}wrist_link">
      <visual>
        <origin xyz="0 0 ${wrist_len/2}"/>
        <geometry><box size="0.040 0.045 ${wrist_len}"/></geometry>
        <material name="aluminio"/>
      </visual>
      <collision>
        <origin xyz="0 0 ${wrist_len/2}"/>
        <geometry><box size="0.045 0.050 ${wrist_len}"/></geometry>
      </collision>
      <xacro:inercia_caja m="0.09" x="0.04" y="0.045" z="${wrist_len}"/>
    </link>

    <!-- E: muñeca roll (gira la garra sobre el eje del brazo) -->
    <joint name="${prefix}wrist_roll_joint" type="revolute">
      <parent link="${prefix}wrist_link"/>
      <child link="${prefix}gripper_base_link"/>
      <origin xyz="0 0 ${wrist_len}"/>
      <axis xyz="0 0 1"/>
      <limit lower="${-lim}" upper="${lim}" effort="${effort_nm}" velocity="${vel_rads}"/>
    </joint>

    <link name="${prefix}gripper_base_link">
      <visual>
        <origin xyz="0 0 ${gripper_base_h/2}"/>
        <geometry><box size="0.045 0.038 ${gripper_base_h}"/></geometry>
        <material name="gris_oscuro"/>
      </visual>
      <collision>
        <origin xyz="0 0 ${gripper_base_h/2}"/>
        <geometry><box size="0.045 0.038 ${gripper_base_h}"/></geometry>
      </collision>
      <xacro:inercia_caja m="0.10" x="0.045" y="0.038" z="${gripper_base_h}"/>
    </link>

    <!-- F: garra de engranajes — dedo izquierdo actuado, derecho espejo (mimic) -->
    <joint name="${prefix}finger_l_joint" type="revolute">
      <parent link="${prefix}gripper_base_link"/>
      <child link="${prefix}finger_l_link"/>
      <origin xyz="0 ${finger_sep/2} ${gripper_base_h}"/>
      <axis xyz="1 0 0"/>
      <limit lower="0.0" upper="1.0" effort="${effort_nm}" velocity="${vel_rads}"/>
    </joint>
    <link name="${prefix}finger_l_link">
      <visual>
        <origin xyz="0 0.004 ${finger_len/2}"/>
        <geometry><box size="0.010 0.008 ${finger_len}"/></geometry>
        <material name="aluminio"/>
      </visual>
      <collision>
        <origin xyz="0 0.004 ${finger_len/2}"/>
        <geometry><box size="0.010 0.008 ${finger_len}"/></geometry>
      </collision>
      <xacro:inercia_caja m="0.02" x="0.01" y="0.008" z="${finger_len}"/>
    </link>

    <joint name="${prefix}finger_r_joint" type="revolute">
      <parent link="${prefix}gripper_base_link"/>
      <child link="${prefix}finger_r_link"/>
      <origin xyz="0 ${-finger_sep/2} ${gripper_base_h}"/>
      <axis xyz="1 0 0"/>
      <limit lower="-1.0" upper="0.0" effort="${effort_nm}" velocity="${vel_rads}"/>
      <mimic joint="${prefix}finger_l_joint" multiplier="-1.0"/>
    </joint>
    <link name="${prefix}finger_r_link">
      <visual>
        <origin xyz="0 -0.004 ${finger_len/2}"/>
        <geometry><box size="0.010 0.008 ${finger_len}"/></geometry>
        <material name="aluminio"/>
      </visual>
      <collision>
        <origin xyz="0 -0.004 ${finger_len/2}"/>
        <geometry><box size="0.010 0.008 ${finger_len}"/></geometry>
      </collision>
      <xacro:inercia_caja m="0.02" x="0.01" y="0.008" z="${finger_len}"/>
    </link>

    <!-- frame de herramienta (punta de la garra, objetivo de IK/MoveIt2) -->
    <joint name="${prefix}tool0_joint" type="fixed">
      <parent link="${prefix}gripper_base_link"/>
      <child link="${prefix}tool0"/>
      <origin xyz="0 0 ${gripper_base_h + finger_len}"/>
    </joint>
    <link name="${prefix}tool0"/>

  </xacro:macro>
</robot>
