<?xml version="1.0"?>
<!--
  ros2_control para el WAVER CRAB en Gazebo (classic) — Fase F1b.
  Interfaz de posición por joint (así se comporta un servo RC: le pides
  posición, él llega). Los dedos derechos son MIMIC (engranaje físico).
-->
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

  <xacro:macro name="joint_pos" params="name initial:=0.0">
    <joint name="${name}">
      <command_interface name="position"/>
      <state_interface name="position">
        <param name="initial_value">${initial}</param>
      </state_interface>
      <state_interface name="velocity"/>
    </joint>
  </xacro:macro>

  <xacro:macro name="joint_mimic" params="name master">
    <joint name="${name}">
      <param name="mimic">${master}</param>
      <param name="multiplier">-1</param>
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
  </xacro:macro>

  <xacro:macro name="arm_control_joints" params="prefix">
    <xacro:joint_pos name="${prefix}yaw_joint"/>
    <xacro:joint_pos name="${prefix}shoulder_joint"/>
    <xacro:joint_pos name="${prefix}elbow_joint"/>
    <xacro:joint_pos name="${prefix}wrist_pitch_joint"/>
    <xacro:joint_pos name="${prefix}wrist_roll_joint"/>
    <xacro:joint_pos name="${prefix}finger_l_joint"/>
    <xacro:joint_mimic name="${prefix}finger_r_joint" master="${prefix}finger_l_joint"/>
  </xacro:macro>

  <xacro:macro name="crab_ros2_control">
    <ros2_control name="crab_system" type="system">
      <hardware>
        <plugin>gazebo_ros2_control/GazeboSystem</plugin>
      </hardware>
      <xacro:joint_pos name="torso_lift_joint"/>
      <xacro:arm_control_joints prefix="left_arm_"/>
      <xacro:arm_control_joints prefix="right_arm_"/>
    </ros2_control>

    <gazebo>
      <plugin filename="libgazebo_ros2_control.so" name="gazebo_ros2_control">
        <parameters>$(find waver_arm_description)/config/controllers.yaml</parameters>
      </plugin>
    </gazebo>
  </xacro:macro>
</robot>
